generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  PATIENT
  RECEPTIONIST
}

enum AppointmentStatus {
  BOOKED
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED_BY_PATIENT
  CANCELLED_BY_RECEPTION
  NO_SHOW
}

enum ReminderChannel {
  TELEGRAM
  EMAIL
  WHATSAPP
}

enum ReminderType {
  T24
  T2
  CONFIRMATION
}

enum ReminderStatus {
  QUEUED
  SENT
  FAILED
  DELIVERED
  CONFIRMED
  CANCELLED
}

model Tenant {
  id        String   @id @default(cuid())
  key       String   @unique
  name      String
  timezone  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinics      Clinic[]
  users        User[]
  patients     PatientProfile[]
  appointments Appointment[]
  auditLogs    AuditLog[]
}

model Clinic {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  timezone  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  providers          Provider[]
  patients           PatientProfile[]
  appointments       Appointment[]
  receptionistAccess ReceptionistClinicAccess[]

  @@index([tenantId])
}

model User {
  id               String   @id @default(cuid())
  tenantId         String
  email            String   @unique
  emailVerified    DateTime?
  name             String?
  image            String?
  role             Role
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  patientProfileId String?  @unique

  tenant         Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patientProfile PatientProfile?          @relation(fields: [patientProfileId], references: [id])
  accounts       Account[]
  sessions       Session[]
  auditLogs      AuditLog[]
  clinicAccess   ReceptionistClinicAccess[]

  @@index([tenantId])
}

model ReceptionistClinicAccess {
  id        String   @id @default(cuid())
  userId    String
  clinicId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([userId, clinicId])
  @@index([clinicId])
}

model PatientProfile {
  id            String   @id @default(cuid())
  tenantId      String
  clinicId      String?
  googleSub     String   @unique
  fullName      String
  phoneE164     String
  preferredChan ReminderChannel @default(TELEGRAM)
  telegramChatId String?
  reminderOptIn Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clinic       Clinic?       @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  user         User?
  appointments Appointment[]

  @@unique([tenantId, phoneE164])
  @@index([tenantId, clinicId])
}

model Provider {
  id        String   @id @default(cuid())
  clinicId  String
  name      String
  specialty String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic       Clinic            @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  schedules    ProviderSchedule[]
  timeOff      ProviderTimeOff[]
  appointments Appointment[]
}

model ProviderSchedule {
  id        String   @id @default(cuid())
  providerId String
  weekday   Int
  startTime String
  endTime   String
  breakJson Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, weekday])
}

model ProviderTimeOff {
  id          String   @id @default(cuid())
  providerId  String
  startAt     DateTime
  endAt       DateTime
  reason      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, startAt, endAt])
}

model Appointment {
  id          String            @id @default(cuid())
  tenantId    String
  clinicId    String
  providerId  String
  patientId   String
  startAt     DateTime
  endAt       DateTime
  status      AppointmentStatus @default(BOOKED)
  source      String
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clinic   Clinic         @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  provider Provider       @relation(fields: [providerId], references: [id], onDelete: Cascade)
  patient  PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  reminders ReminderLog[]

  @@index([tenantId, clinicId, providerId, startAt])
  @@index([tenantId, patientId, status])
}

model ReminderLog {
  id                String         @id @default(cuid())
  appointmentId     String
  channel           ReminderChannel
  type              ReminderType
  status            ReminderStatus @default(QUEUED)
  providerMessageId String?
  errorCode         String?
  errorMessage      String?
  sentAt            DateTime?
  deliveredAt       DateTime?
  respondedAt       DateTime?
  responseAction    String?
  createdAt         DateTime       @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId, type, channel])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  actorId    String?
  actorType  String
  entityType String
  entityId   String
  action     String
  changes    Json?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor  User?  @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId, entityType, entityId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
